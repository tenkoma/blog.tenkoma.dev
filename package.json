    "@astrojs/svelte": "^8.0.5",
    "@shikijs/transformers": "^4.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "^4.2.2",
    "astro": "^6.1.8",
    "astro-custom-embeds": "^0.0.1",
    "astro-og-canvas": "^0.11.1",
    "cheerio": "^1.0.0",
    "lite-youtube-embed": "^0.3.3",
    "rehype-mathjax": "^7.1.0",
